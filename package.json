{
  "name": "casebridge",
  "version": "1.0.0",
  "description": "Bidirectional camelCase ↔ snake_case key transformation for TypeScript/JavaScript — framework-agnostic core with adapters for Angular, Fetch, and Axios.",
  "author": {
    "name": "Kartik"
  },
  "license": "MIT",
  "keywords": [
    "camelcase",
    "snake_case",
    "case-conversion",
    "angular",
    "axios",
    "fetch",
    "http-interceptor",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./angular": {
      "types": "./dist/adapters/angular.d.ts",
      "import": "./dist/adapters/angular.js",
      "require": "./dist/adapters/angular.cjs"
    },
    "./fetch": {
      "types": "./dist/adapters/fetch.d.ts",
      "import": "./dist/adapters/fetch.js",
      "require": "./dist/adapters/fetch.cjs"
    },
    "./axios": {
      "types": "./dist/adapters/axios.d.ts",
      "import": "./dist/adapters/axios.js",
      "require": "./dist/adapters/axios.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "prepublishOnly": "npm run build && npm test"
  },
  "devDependencies": {
    "@angular/common": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@types/jest": "^29.5.12",
    "jest": "^29.7.0",
    "rxjs": "^7.8.1",
    "ts-jest": "^29.1.4",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "@angular/common": ">=16.0.0",
    "@angular/core": ">=16.0.0",
    "axios": ">=1.0.0",
    "rxjs": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "@angular/common": {
      "optional": true
    },
    "@angular/core": {
      "optional": true
    },
    "axios": {
      "optional": true
    },
    "rxjs": {
      "optional": true
    }
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  },
  "repository": {
    "type": "git",
    "url": ""
  }
}
